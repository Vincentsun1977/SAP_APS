# Environment Variables
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Project Settings
PROJECT_NAME=SAP Production Predictor
VERSION=1.0.0
DEBUG=True

# Model Settings
MODEL_VERSION=v1.0
MODEL_PATH=models/

# Feature Engineering
FEATURE_VERSION=v1.0
LOOKBACK_DAYS=30

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Database Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# SAP Connection Configuration
SAP_HOST=sap-server.company.com
SAP_PORT=443
SAP_PROTOCOL=https
SAP_CLIENT=100
SAP_USERNAME=ML_USER
SAP_PASSWORD=your_sap_password_here

# SAP OAuth (if using OAuth instead of Basic Auth)
SAP_CLIENT_ID=your_client_id
SAP_CLIENT_SECRET=your_client_secret
